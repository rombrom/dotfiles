#!/bin/sh
# LLM Wrapper Script
# Usage: cat file.py | ,llm "Explain this code"

function log_debug() {
  [ -z "$DEBUG" ] && return
  printf '\033[90mDEBUG:  %s\n\033[0m' "$*"
}

function log_error() {
  printf '\033[31mERROR:  %s\n\033[0m' "$*" >&2
}

ENDPOINT=${ENDPOINT:-http://localhost:8484}
SYSTEM_PROMPT=$(cat << EOF
You are an expert programmer assistant.

- When given code as context and a query about that code, your response should be concise and focused on the specific task requested.
- If the query is about modifying or creating code, provide only the code changes needed. Do not wrap in "\`\`\`".

**Avoid verbose explanations unless specifically requested. Keep responses technical and to the point.**
EOF)
TOOLS=$(jq -n '[
    {
        type: "function",
        name: "exec_bash",
        description: "Execute shell commands.",
        parameters: {
            type: "object",
            properties: {
                command: {
                    type: "string",
                    description: "The command to execute."
                }
            },
            required: ["command"]
        },
        strict: true
    }
]')

log_debug "ENDPOINT:     " $ENDPOINT
log_debug "SYSTEM_PROMPT:" $SYSTEM_PROMPT
log_debug "TOOLS:        " $TOOLS

# Check if jq is available
if ! command -v jq >/dev/null 2>&1; then
    log_error "jq is required but not installed"
    exit 1
fi

# Get the query from command line argument
query="$*"

# If no query provided, exit with error
if [ $# -eq 0 ]; then
    log_error "No query provided"
    exit 1
fi

# Check if stdin is available (not a terminal)
if [ ! -t 0 ]; then
    # Read all stdin into a variable (context)
    context=$(cat)
else
    # No stdin provided, so we'll use only the query
    context=""
fi

# Create JSON using jq for proper escaping
json=$(jq -n --arg SYSTEM_PROMPT "$SYSTEM_PROMPT" --argjson TOOLS "$TOOLS" --arg query "$query" '{
    messages: [
        {role: "system", content: $SYSTEM_PROMPT},
        {role: "user", content: $query}
    ],
    # tools: $TOOLS
}')

# Prepend context if we have it
if [ ${#context} -gt 0 ]; then
  json=$(printf '%s' "$json" | jq --arg context "$context" '.messages = [
        {role: "user", content: $context}
  ] + .messages')
fi

log_debug ">>" "$json"

# Send request to local LLM endpoint using curl
response=$(curl -s -X POST $ENDPOINT/v1/chat/completions \
    -H "Content-Type: application/json" \
    -d "$json")

log_debug "<<" "$response"

error=$(printf '%s' "$response" | jq -r 'if has("error") then .error.message else empty end')
output=$(printf '%s' "$response" | jq -r 'if has("choices") then .choices[0].message.content end')

if [ -n "$error" ]; then
  log_error "$error"
  exit 1
fi

printf '%s\n' "$output"
