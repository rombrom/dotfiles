#!/bin/sh
# LLM Wrapper Script
# Usage: cat file.py | ,llm "Explain this code"

function log_debug() {
  [ -z "$DEBUG" ] && return
  printf '\033[90mDEBUG:  %s\n\033[0m' "$*"
}

function log_error() {
  printf '\033[31mERROR:  %s\n\033[0m' "$*" >&2
}

ENDPOINT=${ENDPOINT:-http://localhost:8484/v1/messages}
SYSTEM_PROMPT=$(cat << EOF
You are an expert programmer assistant.

- When given code as context and a query about that code, your response should be concise and focused on the specific task requested.
- If the query is about modifying or creating code, provide only the code changes needed. Do not wrap in "\`\`\`".

**Avoid verbose explanations unless specifically requested. Keep responses technical and to the point.**

When you need to execute shell commands, use the `exec_shell` tool:
- The tool expects a command parameter with the shell command to execute
- This is for running commands like 'ls', 'grep', 'find', etc.
EOF)
TOOLS=$(jq -n '[
    {
        type: "function",
        name: "exec_shell",
        description: "Execute shell commands.",
        parameters: {
            type: "object",
            properties: {
                command: {
                    type: "string",
                    description: "The command to execute."
                }
            },
            required: ["command"]
        },
        strict: true
    }
]')

log_debug "ENDPOINT:     " $ENDPOINT
log_debug "SYSTEM_PROMPT:" $SYSTEM_PROMPT

# Check if jq is available
if ! command -v jq >/dev/null 2>&1; then
    log_error "jq is required but not installed"
    exit 1
fi

# Get the query from command line argument
query="$*"

# If no query provided, exit with error
if [ $# -eq 0 ]; then
    log_error "No query provided"
    exit 1
fi

# Check if stdin is available (not a terminal)
if [ ! -t 0 ]; then
    # Read all stdin into a variable (context)
    context=$(cat)
else
    # No stdin provided, so we'll use only the query
    context=""
fi

# Build messages array properly for Claude API
if [ ${#context} -gt 0 ]; then
    # Both context and query are present
    messages=$(jq -n --arg context "$context" --arg query "$query" '[
        {role: "user", content: $context},
        {role: "user", content: $query}
    ]')
else
    # Only query is present
    messages=$(jq -n --arg query "$query" '[{role: "user", content: $query}]')
fi

# Create JSON request for Claude Messages API with tools support
json=$(jq -n --argjson messages "$messages" --arg SYSTEM_PROMPT "$SYSTEM_PROMPT" --argjson TOOLS "$TOOLS" '{
    messages: $messages,
    system: $SYSTEM_PROMPT,
    tools: $TOOLS
}')

log_debug ">>" "$json"

# Send request to Claude Messages API using curl
response=$(curl -s --json "$json" $ENDPOINT)

log_debug "<<" "$(printf '%s' "$response" | jq)"

error=$(printf '%s' "$response" | jq -r 'if has("error") then .error.message else empty end')
output=$(printf '%s' "$response" | jq -r '.content[0].text')

if [ -n "$error" ]; then
  log_error "$error"
  exit 1
fi

printf '%s\n' "$output"
