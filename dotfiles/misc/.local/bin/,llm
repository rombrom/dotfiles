#!/usr/bin/env node

class MessageChannel {
  #handler = class Messages {
    static #last_type = undefined;

    static content_block_start(data) {
      if (this.#last_type && this.#last_type !== data.content_block.type)
        process.stderr.write("\n\x1b[0m");

      switch (data.content_block.type) {
        case "thinking":
          if (process.stderr.isTTY) process.stderr.write("\n\x1b[90m");
          break;
      }

      this.#last_type = data.content_block.type;
    }

    static content_block_delta(data) {
      switch (data.delta.type) {
        case "thinking_delta":
          if (process.stderr.isTTY) process.stderr.write(data.delta.thinking);
          break;
        case "text_delta":
          process.stdout.write(data.delta.text);
          break;
      }
    }

    static message_stop() {
      process.stdout.write("\n");
    }
  };

  event(event) {
    let raw = [],
      type;

    for (let line of event.split("\n")) {
      line = line.trim();
      switch (true) {
        case line.startsWith("event:"):
          type = line.slice(6).trim();
          break;
        case line.startsWith("data:"):
          raw.push(line.slice(5).trim());
          break;
      }
    }

    raw = raw.join("\n");

    return { data: this.safeJSON(raw), raw, type };
  }

  handle(event) {
    const { data, type } = this.event(event);
    this.#handler[type]?.(data);
  }

  safeJSON(str) {
    try {
      return JSON.parse(str);
    } catch {
      console.error("Unable to parse JSON");
      return str;
    }
  }
}

const ENDPOINT =
  process.env.LLM_ENDPOINT ?? "http://localhost:8484/v1/messages";

const TIMEOUT_MS = parseInt(process.env.LLM_TIMEOUT_MS, 10) || 30000; // Default 30s

const system =
  process.env.LLM_SYSTEM_PROMPT ??
  `You are a concise CLI assistant. When given two successive messages: first message is context, second is query. Direct answers only; no preamble. Code: plain text snippets (no \`\`\`) + steps (in comments). Non-code: brief. Do not over-analyze context unless requested.`;

const messages = [];
const tools = [];
const stream = process.stdout.isTTY;

// Setup AbortController for timeout and cancellation
const controller = new AbortController();
let timeoutId = setTimeout(() => controller.abort(), TIMEOUT_MS);

// Reset timeout on activity (sliding window)
const resetTimeout = () => {
  clearTimeout(timeoutId);
  timeoutId = setTimeout(() => controller.abort(), TIMEOUT_MS);
};

const context = await (async () => {
  if (process.stdin.isTTY) return;

  const chunks = [];
  for await (const chunk of process.stdin) chunks.push(chunk);
  return chunks.join("");
})();

const query = process.argv.slice(2).join(" ").trim();

if (context) messages.push({ content: context, role: "user" });
if (query) messages.push({ content: query, role: "user" });

const res = await fetch(ENDPOINT, {
  body: JSON.stringify({
    messages,
    system,
    tools,
    stream,
  }),
  method: "POST",
  signal: controller.signal,
});

if (!res.ok) {
  clearTimeout(timeoutId);
  throw new Error(`Response not OK: ${res.status} ${res.statusText}`);
}

// Handle abort/timeout
if (controller.signal.aborted) {
  clearTimeout(timeoutId);
  process.stderr.write("\n\x1b[31mRequest aborted (timeout or cancelled)\x1b[0m\n");
  process.exit(1);
}

if (res.headers.get("content-type")?.includes("text/event-stream")) {
  const decoder = new TextDecoder();
  const reader = res.body.getReader();
  const llm = new MessageChannel();

  let buffer = "";

  try {
    while (true) {
      resetTimeout(); // Extend timeout on every read activity

      const { done, value } = await reader.read();

      if (done) break;
      if (!value) continue;

      buffer += decoder.decode(value);

      while (buffer.includes("\n\n")) {
        const [event, ...rest] = buffer.split("\n\n");
        buffer = rest.join("\n\n");
        resetTimeout(); // Extend timeout on every event received
        llm.handle(event);
      }
    }

    if (buffer.trim()) {
      resetTimeout(); // Extend timeout on last partial event
      llm.handle(buffer);
    }
  } finally {
    clearTimeout(timeoutId);
    reader.cancel();
  }
}

if (res.headers.get("content-type")?.includes("application/json")) {
  resetTimeout(); // Ensure timeout won't fire during JSON parsing
  const data = await res.json();
  clearTimeout(timeoutId);

  const { text, thinking } = data.content.reduce((out, row) => {
    out[row.type] = out[row.type]
      ? `${out[row.type]}\n${row[row.type]}`
      : row[row.type];
    return out;
  }, {});

  if (thinking && process.stderr.isTTY)
    process.stderr.write(`\x1b[90m${thinking}\x1b[0m\n`);

  if (text) process.stdout.write(`${text}\n`);
}
